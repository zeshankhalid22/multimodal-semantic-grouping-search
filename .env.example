# Database
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ML Model
MODEL_NAME=ViT-B-32
MODEL_PATH=best_openclip_model.pt

# Images
IMAGE_ROOT=

# Search
HNSW_EF_SEARCH=40
SEARCH_LIMIT=5

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Admin
ADMIN_PASSWORD=change_me_in_production

# Browser (used by the Amazon scraper)
BROWSER_BINARY=/usr/bin/microsoft-edge
